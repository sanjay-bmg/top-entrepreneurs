# Google Sheets — base64-encoded service account JSON
# Run: base64 -i your-service-account.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_JSON=

# The ID of the Google Sheet where leads are stored (from the Sheet URL)
# Tabs: "Applications", "Contact", "Featured-City"
LEADS_SHEET_ID=

# SendGrid API key (sends lead-notification emails).
# Recipients, From, and Reply-To are configured in site.config.ts.
SENDGRID_API_KEY=

# Public site URL (used in emails and traffic-source tracking)
NEXT_PUBLIC_SITE_URL=https://topentrepreneurs.com
